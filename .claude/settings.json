{
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Skill(run)",
      "Skill(run:*)",
      "Bash(pkill -f \"next dev\")",
      "Bash(chromium-cli --session portfolio)",
      "Bash(which chromium *)",
      "Read(//Applications/**)",
      "Bash(curl -sf http://localhost:3000)",
      "Bash(cat /tmp/portfolio-dev.log | grep -E \"\\(Error|Warning|error\\)\" | head -20)",
      "Read(//private/tmp/**)",
      "Bash(lsof -ti:3000)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(pkill -f \"next-server\")",
      "Bash(echo \"Server PID: $!\")",
      "Bash(curl -s http://localhost:3000)",
      "Bash(kill 66786)",
      "Bash(echo \"PID: $!\")"
    ]
  }
